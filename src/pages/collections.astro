---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchAllWithCache, urlFor } from '../lib/sanity.js';
import { getCategories as getLocalCategories } from '../data/photos.js';

// ── Fetch categories from Sanity → Cache → Local ────────────────
let allCategories = [];

const { categories: rawCats, source } = await fetchAllWithCache();

if ((source === 'sanity' || source === 'cache') && rawCats && rawCats.length > 0) {
  allCategories = rawCats.map(c => ({
    name:        c.name,
    slug:        c.slug,
    description: c.description || '',
    archetype:   c.archetype || '',
    archetypeDescription: c.archetypeDescription || '',
    count:       c.photoCount || 0,
    isParent:    c.isParent || false,
    parentCategory: c.parentCategory || null,
    children:    (c.children || []).map(child => ({
      name:  child.name,
      slug:  child.slug,
      count: child.photoCount || 0,
    })),
    photos:      (c.previewPhotos || [])
      .filter(p => p.image)
      .map(p => ({
        title: p.title || 'Untitled',
        slug:  p.slug,
        img:   urlFor(p.image).width(400).height(500).quality(60).auto('format').url()
      }))
  }));
} else {
  const localCats = getLocalCategories();
  allCategories = localCats.map(c => ({
    name: c.name,
    slug: c.slug,
    description: '',
    archetype: '',
    archetypeDescription: '',
    count: c.count || 0,
    isParent: false,
    parentCategory: null,
    children: [],
    photos: []
  }));
}

// ── Build display list: show parent categories and standalone categories ──
// Hide child categories from the main list (they appear as subcategories under their parent)
const displayCategories = allCategories.filter(c => !c.parentCategory);

// Total artwork count (count from top-level + standalone only, to avoid double counting)
const totalCount = displayCategories.reduce((sum, c) => {
  if (c.isParent && c.children.length > 0) {
    // For parent categories, sum children counts
    return sum + c.children.reduce((cs, child) => cs + child.count, 0);
  }
  return sum + c.count;
}, 0);
---

<BaseLayout title="Collections — Alba Tull">
  <div class="collections-page">
    <div class="collections-header">
      <a class="collections-back" href="/">&larr; Home</a>
      <h1 class="collections-title">The Collection</h1>
      <p class="collections-subtitle">{totalCount} Artworks across {displayCategories.length} Collections</p>
    </div>

    <div class="collections-list">
      {displayCategories.map(cat => (
        <div class="collection-row">
          <div class="collection-info">
            <div class="collection-info-left">
              {cat.archetype && (
                <div class="collection-archetype">Archetype</div>
              )}
              <h2 class="collection-name">
                <a href={`/category/${cat.slug}/`}>
                  {cat.archetype || cat.name}
                </a>
                <span class="collection-count">
                  {cat.isParent && cat.children.length > 0
                    ? cat.children.reduce((s, ch) => s + ch.count, 0)
                    : cat.count}
                </span>
              </h2>
              {/* Show subcategory labels for parent categories */}
              {cat.isParent && cat.children.length > 0 && (
                <div class="collection-subcategories">
                  {cat.children.map((child, i) => (
                    <Fragment>
                      <a href={`/category/${child.slug}/`} class="collection-subcat-link">
                        {child.name} ({child.count})
                      </a>
                      {i < cat.children.length - 1 && <span class="collection-subcat-sep"> · </span>}
                    </Fragment>
                  ))}
                </div>
              )}
            </div>
            <div class="collection-info-right">
              <p class="collection-tagline">
                {cat.archetypeDescription || cat.description || `${cat.count} photographs in this collection.`}
              </p>
            </div>
          </div>

          <div class="collection-strip">
            {cat.photos.map(photo => (
              <a
                class="collection-thumb"
                href={`/photo/${photo.slug}/`}
              >
                <img src={photo.img} alt={photo.title} loading="lazy" decoding="async" />
              </a>
            ))}
            {cat.photos.length === 0 && (
              <div class="collection-empty">Photos loading from Sanity...</div>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Grid view -->
    <div class="collections-grid-view" style="display:none;">
      {displayCategories.map(cat => (
        <div class="grid-category-section">
          <div class="grid-category-header">
            <h3 class="grid-category-name">
              <a href={`/category/${cat.slug}/`}>{cat.name}</a>
              <span class="collection-count">{cat.count}</span>
            </h3>
          </div>
          <div class="grid-category-photos">
            {cat.photos.map(photo => (
              <a class="grid-small-tile" href={`/photo/${photo.slug}/`}>
                <img src={photo.img} alt={photo.title} loading="lazy" decoding="async" />
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- View toggle -->
    <div class="view-toggle">
      <button class="view-toggle-btn view-toggle-active" id="canvasBtn">Canvas</button>
      <button class="view-toggle-btn" id="gridBtn">Grid</button>
    </div>
  </div>

  <script>
    (function() {
      var canvasBtn = document.getElementById('canvasBtn');
      var gridBtn = document.getElementById('gridBtn');
      var canvasView = document.querySelector('.collections-list');
      var gridView = document.querySelector('.collections-grid-view');
      if (!canvasBtn || !gridBtn || !canvasView || !gridView) return;

      function showCanvas() {
        canvasView.style.display = '';
        gridView.style.display = 'none';
        canvasBtn.classList.add('view-toggle-active');
        gridBtn.classList.remove('view-toggle-active');
      }

      function showGrid() {
        canvasView.style.display = 'none';
        gridView.style.display = '';
        gridBtn.classList.add('view-toggle-active');
        canvasBtn.classList.remove('view-toggle-active');
      }

      canvasBtn.addEventListener('click', showCanvas);
      gridBtn.addEventListener('click', showGrid);

      if (window.location.search.indexOf('view=grid') !== -1) {
        showGrid();
      }
    })();
  </script>
</BaseLayout>
